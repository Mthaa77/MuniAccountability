# MuniAccountability Command environment template
# Copy this to .env.local for local development. Do not commit real secrets.

# Runtime mode
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_REQUIRE_AUTH=false
NODE_ENV=development

# Firebase web app config (safe public values from Firebase project settings)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GCP / Firebase Admin preparation
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Workflow store provider
# local_json keeps the current prototype write path.
# firestore is the prepared hosted workflow target once Firebase Admin credentials are configured.
WORKFLOW_STORE_PROVIDER=local_json
WORKFLOW_TENANT_ID=prototype

# Authentication and RBAC
# Demo mode uses MUNI_DEV_ROLE and does not require a signed session cookie.
# Supported roles: public, viewer, analyst, reviewer, admin, super_admin.
MUNI_DEV_ROLE=admin

# Required when NEXT_PUBLIC_REQUIRE_AUTH=true.
# Use a random secret with at least 32 characters and store it only in a secret manager.
MUNI_SESSION_SECRET=

# Future Firebase session exchange endpoint should verify the Firebase ID token server-side,
# resolve tenant/role claims and issue the short-lived HttpOnly muni_session cookie.

# Cost-control defaults
GCP_BUDGET_ALERT_RAND=100
DISABLE_EXPENSIVE_JOBS=true
