# MuniAccountability Command environment template
# Copy this to .env.local for local development. Do not commit real secrets.

# Runtime mode
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_REQUIRE_AUTH=false
NODE_ENV=development

# Firebase web app config (safe public values from Firebase project settings)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GCP / Firebase Admin preparation
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Workflow store provider
# local_json keeps the current prototype write path.
# firestore is the prepared hosted workflow target once Firebase Admin credentials are configured.
WORKFLOW_STORE_PROVIDER=local_json
WORKFLOW_TENANT_ID=prototype

# Auth guard preparation
# In demo mode, the middleware does not block routes.
# When REQUIRE_AUTH=true, provide a Firebase session layer before using this in production.
MUNI_DEV_ROLE=admin

# Cost-control defaults
GCP_BUDGET_ALERT_RAND=100
DISABLE_EXPENSIVE_JOBS=true
