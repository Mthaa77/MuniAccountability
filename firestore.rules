rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role is string ? request.auth.token.role : 'public';
    }

    function tokenTenantId() {
      return signedIn() && request.auth.token.tenantId is string ? request.auth.token.tenantId : '';
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function belongsToTenant(tenantId) {
      return signedIn() && (isSuperAdmin() || tokenTenantId() == tenantId);
    }

    function hasAnyRole(allowed) {
      return signedIn() && role() in allowed;
    }

    match /tenants/{tenantId}/publicProfiles/{document=**} {
      allow read: if true;
      allow write: if belongsToTenant(tenantId) && hasAnyRole(['admin', 'super_admin']);
    }

    match /tenants/{tenantId}/reviewDecisions/{decisionKey} {
      allow read: if belongsToTenant(tenantId) && hasAnyRole(['reviewer', 'admin', 'super_admin']);
      allow create, update: if belongsToTenant(tenantId) && hasAnyRole(['reviewer', 'admin', 'super_admin']);
      allow delete: if belongsToTenant(tenantId) && hasAnyRole(['admin', 'super_admin']);
    }

    match /tenants/{tenantId}/productionGateReviews/{decisionKey} {
      allow read, write: if belongsToTenant(tenantId) && hasAnyRole(['admin', 'super_admin']);
    }

    match /tenants/{tenantId}/draftActions/{actionId} {
      allow read: if belongsToTenant(tenantId) && hasAnyRole(['viewer', 'analyst', 'reviewer', 'admin', 'super_admin']);
      allow create, update: if belongsToTenant(tenantId) && hasAnyRole(['analyst', 'reviewer', 'admin', 'super_admin']);
      allow delete: if belongsToTenant(tenantId) && hasAnyRole(['admin', 'super_admin']);
    }

    match /tenants/{tenantId}/auditLogs/{eventId} {
      allow read: if belongsToTenant(tenantId) && hasAnyRole(['admin', 'super_admin']);
      allow create: if belongsToTenant(tenantId) && hasAnyRole(['analyst', 'reviewer', 'admin', 'super_admin']);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
