rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role is string ? request.auth.token.role : 'public';
    }

    function hasAnyRole(allowed) {
      return signedIn() && role() in allowed;
    }

    match /tenants/{tenantId}/publicProfiles/{document=**} {
      allow read: if true;
      allow write: if hasAnyRole(['admin']);
    }

    match /tenants/{tenantId}/reviewDecisions/{decisionKey} {
      allow read: if hasAnyRole(['reviewer', 'admin']);
      allow create, update: if hasAnyRole(['reviewer', 'admin']);
      allow delete: if hasAnyRole(['admin']);
    }

    match /tenants/{tenantId}/productionGateReviews/{decisionKey} {
      allow read, write: if hasAnyRole(['admin']);
    }

    match /tenants/{tenantId}/draftActions/{actionId} {
      allow read: if hasAnyRole(['analyst', 'reviewer', 'admin']);
      allow create, update: if hasAnyRole(['analyst', 'reviewer', 'admin']);
      allow delete: if hasAnyRole(['admin']);
    }

    match /tenants/{tenantId}/auditLogs/{eventId} {
      allow read: if hasAnyRole(['admin']);
      allow create: if hasAnyRole(['analyst', 'reviewer', 'admin']);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
